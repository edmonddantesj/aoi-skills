<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>ai.aoi.handoff-compact-daily</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/bash</string>
      <string>/Users/mercedes/.openclaw/workspace/scripts/handoff_compact_daily.sh</string>
    </array>

    <!-- 09:30 KST daily -->
    <key>StartCalendarInterval</key>
    <array>
      <dict>
        <key>Hour</key><integer>9</integer>
        <key>Minute</key><integer>30</integer>
      </dict>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/mercedes/.openclaw/workspace</string>

    <key>StandardOutPath</key>
    <string>/Users/mercedes/.openclaw/workspace/logs/launchd/handoff-compact-daily.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/mercedes/.openclaw/workspace/logs/launchd/handoff-compact-daily.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
      <key>PATH</key>
      <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
      <key>TZ</key>
      <string>Asia/Seoul</string>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>ThrottleInterval</key>
    <integer>60</integer>
  </dict>
</plist>
