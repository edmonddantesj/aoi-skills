<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.aoineco.xpost.tick</string>

    <key>ProgramArguments</key>
    <array>
      <string>/Users/silkroadcat/.openclaw/workspace/scripts/xpost_tick.sh</string>
    </array>

    <!-- 08:10 / 12:10 / 18:10 KST -->
    <key>StartCalendarInterval</key>
    <array>
      <dict><key>Hour</key><integer>8</integer><key>Minute</key><integer>10</integer></dict>
      <dict><key>Hour</key><integer>12</integer><key>Minute</key><integer>10</integer></dict>
      <dict><key>Hour</key><integer>18</integer><key>Minute</key><integer>10</integer></dict>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/silkroadcat/.openclaw/workspace</string>

    <key>StandardOutPath</key>
    <string>/Users/silkroadcat/.openclaw/workspace/artifacts/x-post/_logs/launchd.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/silkroadcat/.openclaw/workspace/artifacts/x-post/_logs/launchd.stderr.log</string>

    <key>RunAtLoad</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>60</integer>
  </dict>
</plist>
